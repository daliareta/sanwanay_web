                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center font-bold text-blue-600">AH</div>
                    <div>
                        <h4 class="font-bold text-blue-900">Ahmad Hidayat</h4>
                        <p class="text-xs text-slate-400">Warga Jambu Karya</p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-xl border border-slate-100 hover:-translate-y-2 transition-all">
