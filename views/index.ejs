<%- include('partials/header') %>

<header class="relative bg-gradient-to-r from-blue-700 to-blue-500 py-24 text-white text-center">
    <div class="container mx-auto px-6">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-4 animate-fade-in">Sanwanay Network:<br>Internet Cepat, Harga Sahabat!</h1>
        <p class="text-xl mb-8 opacity-90">Pasang WiFi Sanwanay Network sekarang di Rajeg & sekitarnya. Unlimited tanpa FUP untuk rumah & bisnis Anda.</p>
        <div class="flex justify-center gap-4">
            <a href="/paket" class="bg-yellow-400 text-blue-900 px-8 py-3 rounded-full font-bold hover:bg-yellow-300 shadow-lg transition">Daftar Sekarang</a>
            <a href="/about" class="border-2 border-white px-8 py-3 rounded-full font-bold hover:bg-white hover:text-blue-600 transition">Lihat Profil</a>
