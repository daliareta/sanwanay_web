<%- include('partials/header') %>

<main class="container mx-auto mt-10 px-4 mb-20">
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-3xl shadow-2xl border border-slate-100">
        <h2 class="text-3xl font-black text-blue-900 mb-2">FORM PENDAFTARAN</h2>
        <p class="text-slate-500 mb-8">Isi data di bawah untuk pemasangan baru Sanwanay Network.</p>

        <form action="/proses-daftar" method="POST" enctype="multipart/form-data" class="space-y-6">
            <div>
                <label class="block font-bold text-slate-700 mb-2">Nama Lengkap (Sesuai KTP)</label>
                <input type="text" name="nama" required class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block font-bold text-slate-700 mb-2">Nomor Telepon/WA</label>
                    <input type="tel" name="phone" placeholder="0812..." required class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block font-bold text-slate-700 mb-2">Pilih Paket</label>
                    <select name="paket" class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500">
                        <option>Basic (10 Mbps)</option>
                        <option>Silver (20 Mbps)</option>
                        <option>Gold (30 Mbps)</option>
                        <option>Platinum (100 Mbps)</option>
                    </select>
                </div>
            </div>

            <div>
                <label class="block font-bold text-slate-700 mb-2">Alamat Lengkap Pemasangan</label>
                <textarea id="alamatInput" name="alamat" rows="3" required class="w-full px-4 py-3 rounded-xl bg-slate-50 border border-slate-200 outline-none focus:ring-2 focus:ring-blue-500" placeholder="Jl. Contoh No. 123..."></textarea>
            </div>

            <div>
                <label class="block font-bold text-slate-700 mb-2">Pilih Lokasi di Peta (Opsional)</label>
                <p class="text-[10px] text-slate-500 mb-2">Klik pada peta sesuai lokasi rumah Anda untuk memudahkan teknisi.</p>
                <div id="mapSelect" class="w-full h-[300px] rounded-2xl border-4 border-slate-50 shadow-inner"></div>
            </div>

            <div>
                <label class="block font-bold text-slate-700 mb-2">Foto KTP (Jelas)</label>
                <input type="file" name="ktp" accept="image/*" required class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
            </div>

            <button type="submit" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold text-lg hover:bg-blue-700 transition shadow-lg">
                Kirim Data Pendaftaran
            </button>
        </form>
    </div>
</main>

<script>
    const center = [-6.12889, 106.47298]; // Default start point
    const map = L.map('mapSelect').setView(center, 13);

    const street = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© Sanwanay'
    }).addTo(map);

    const satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: 'Tiles &copy; Esri'
    });

    const baseMaps = {
        "Peta Jalan": street,
        "Satelit": satellite
    };

    L.control.layers(baseMaps).addTo(map);

    let marker;
    map.on('click', function(e) {
        const lat = e.latlng.lat.toFixed(6);
        const lng = e.latlng.lng.toFixed(6);
        
        if (marker) {
            marker.setLatLng(e.latlng);
        } else {
            marker = L.marker(e.latlng).addTo(map);
        }

        const alamatField = document.getElementById('alamatInput');
        const coordText = ` [Koordinat: ${lat}, ${lng}]`;
        
        // Cek apakah sudah ada koordinat, kalau ada ganti, kalau tidak ada tambah
        if (alamatField.value.includes('[Koordinat:')) {
            alamatField.value = alamatField.value.replace(/\[Koordinat:.*?\]/, coordText);
        } else {
            alamatField.value += coordText;
        }
    });
</script>

<%- include('partials/footer') %>