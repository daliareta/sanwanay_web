<%- include('partials/header') %>

<main class="container mx-auto mt-10 px-4 mb-20">
    <div class="max-w-5xl mx-auto">
        
        <div class="text-center mb-10">
            <h1 class="text-3xl md:text-5xl font-black text-blue-900 mb-2 uppercase tracking-tighter">
                Area Jangkauan <span class="text-yellow-500">Sanwanay</span>
            </h1>
            <p class="text-slate-600 font-bold">Pusat Layanan: Desa Jambu Karya, Kec. Rajeg, Kab. Tangerang</p>
        </div>

        <div class="bg-white p-4 rounded-[2.5rem] shadow-2xl border border-slate-100 mb-10">
            <div class="p-6 flex justify-between items-center flex-wrap gap-4">
                <div>
                    <h2 class="text-2xl font-black text-blue-900 mb-2 uppercase">PETA SINYAL FIBER</h2>
                    <p class="text-slate-500 text-sm">Titik pusat: **Kampung Jambu Karya RT 07/01**</p>
                </div>
                <div class="flex gap-2 text-[10px] font-bold">
                    <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full border border-blue-200 uppercase">Jambu Karya (Core)</span>
                    <span class="bg-yellow-100 text-yellow-700 px-3 py-1 rounded-full border border-yellow-200 uppercase">Rajeg Area</span>
                </div>
            </div>
            <div id="map" class="w-full h-[500px] rounded-[2rem] z-0 border-4 border-slate-50"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
            
            <div class="md:col-span-2 bg-white p-8 md:p-12 rounded-3xl shadow-2xl border border-slate-100">
                <h2 class="text-3xl font-black mb-2 text-blue-900 italic uppercase">CEK WILAYAHMU</h2>
                <p class="text-slate-500 mb-8">Masukkan nama desa di Kabupaten Tangerang</p>
                
                <div class="flex flex-col md:flex-row gap-4 mb-6">
                    <input type="text" id="inputWilayah" placeholder="Contoh: Jambu Karya / Cirumpak..." 
                           class="flex-1 px-6 py-4 rounded-2xl bg-slate-50 border border-slate-200 outline-none focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all text-slate-700 font-bold uppercase">
                    <button onclick="cekSekarang()" class="bg-blue-600 text-white px-10 py-4 rounded-2xl font-black hover:bg-blue-800 hover:-translate-y-1 transition-all shadow-lg shadow-blue-200 uppercase">
                        Cek Lokasi
                    </button>
                </div>

                <div id="boxHasil" class="hidden p-6 rounded-2xl text-center font-black mb-8 animate-bounce-short"></div>

                <div class="border-t border-slate-100 pt-8">
                    <p class="font-black text-blue-900 mb-4 flex items-center uppercase text-sm tracking-widest">
                        <span class="mr-2">🚀</span> Daftar Desa Tercover (Rajeg & Sekitarnya):
                    </p>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-[10px] font-black uppercase tracking-tighter">
                        <div class="bg-blue-900 text-white p-2 rounded-lg text-center border-b-4 border-yellow-400">JAMBU KARYA</div>
                        <div class="bg-blue-50 text-blue-700 p-2 rounded-lg text-center border border-blue-100">RAJEG</div>
                        <div class="bg-blue-50 text-blue-700 p-2 rounded-lg text-center border border-blue-100">CIRUMPAK</div>
                        <div class="bg-blue-50 text-blue-700 p-2 rounded-lg text-center border border-blue-100">LEGOK SUKAMAJU</div>
                        <div class="bg-blue-50 text-blue-700 p-2 rounded-lg text-center border border-blue-100">KEMIRI</div>
                        <div class="bg-green-50 text-green-700 p-2 rounded-lg text-center border border-green-100">KEMUNING</div>
                        <div class="bg-yellow-50 text-yellow-700 p-2 rounded-lg text-center border border-yellow-100">SINDANG JAYA</div>
                        <div class="bg-red-50 text-red-700 p-2 rounded-lg text-center border border-red-100">BUNI AYU</div>
                    </div>
                </div>
            </div>

            <div class="bg-blue-900 text-white p-8 rounded-3xl shadow-2xl sticky top-24">
                <h3 class="text-xl font-black mb-4 uppercase text-yellow-400">Hubungi Kami</h3>
                <p class="text-sm opacity-80 mb-6">Jika desamu belum terdaftar, jangan khawatir! Tim teknis Sanwanay siap survei lokasi untuk penarikan kabel fiber baru.</p>
                <div class="space-y-4">
                    <a href="https://wa.me/6289560195444" class="flex items-center gap-3 bg-white/10 p-3 rounded-xl hover:bg-white/20 transition">
                        <span class="text-2xl">📱</span>
                        <div class="text-xs">
                            <p class="opacity-60">WhatsApp Admin</p>
                            <p class="font-bold">+62 895-6019-5444</p>
                        </div>
                    </a>
                    <div class="flex items-center gap-3 bg-white/10 p-3 rounded-xl">
                        <span class="text-2xl">📍</span>
                        <div class="text-xs">
                            <p class="opacity-60">Pusat Layanan</p>
                            <p class="font-bold">Desa Jambu Karya, Rajeg</p>
                        </div>
                    </div>
                </div>
                <img src="/images/logo.png" alt="Sanwanay Logo" class="w-20 h-20 mx-auto mt-8 opacity-20 grayscale brightness-200">
            </div>

        </div>

    </div>
</main>

<script>
// 1. SETTING PETA (Koordinat Desa Jambu Karya - RT 07/01)
const koordinatKantor = [-6.128528, 106.463611]; 
const map = L.map('map').setView(koordinatKantor, 16); 

// TILE LAYERS
const street = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© Sanwanay Network'
});

const satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Tiles &copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EBP, and the GIS User Community'
}).addTo(map); // DEFAULT SATELLITE (ATAP RUMAH)

const baseMaps = {
    "Peta Jalan": street,
    "Satelit (Atap Rumah)": satellite
};

L.control.layers(baseMaps).addTo(map);

// 1.5 KLIK PETA UNTUK KOORDINAT
map.on('click', function(e) {
    const lat = e.latlng.lat.toFixed(6);
    const lng = e.latlng.lng.toFixed(6);
    L.popup()
        .setLatLng(e.latlng)
        .setContent(`
            <div class="text-center p-1">
                <b class="text-blue-900 text-[10px] uppercase">LOKASI TERPILIH</b><br>
                <p class="text-[8px] text-slate-500 mb-2">${lat}, ${lng}</p>
                <a href="https://wa.me/6289560195444?text=Halo Admin Sanwanay, saya mau pasang WiFi di koordinat: ${lat}, ${lng}" target="_blank" class="bg-green-600 text-white px-3 py-1 rounded-full text-[10px] font-black uppercase">Daftar via WA</a>
            </div>
        `)
        .openOn(map);
});

// 2. ICON LOGO CUSTOM (LEBIH JELAS & MINIM PUTIH)
const kantorIcon = L.icon({
    iconUrl: '/images/logo.png',
    iconSize: [50, 50],
    iconAnchor: [25, 50],
    popupAnchor: [0, -50],
    className: 'rounded-full border-2 border-yellow-400 bg-blue-900 shadow-xl'
});

// 3. MARKER KANTOR PUSAT
const markerKantor = L.marker(koordinatKantor, { icon: kantorIcon }).addTo(map);
markerKantor.bindPopup(`
    <div class="text-center p-2">
        <b class="text-blue-900 text-lg uppercase">SANWANAY CORE (PUSAT)</b><br>
        <p class="text-[10px] text-slate-500 mb-2">Kp. Jambu Karya RT.07/ RW. 01, Rajeg</p>
        <a href="https://www.google.com/maps?q=${koordinatKantor[0]},${koordinatKantor[1]}" target="_blank" class="bg-blue-600 text-white px-4 py-1 rounded-full text-[10px] font-black uppercase">Petunjuk Arah</a>
    </div>
`).openPopup();

// 4. DATA AREA JANGKAUAN (WARNA LEBIH TAJAM)
const areas = [
    { name: "JAMBU KARYA (PUSAT)", coords: [-6.128528, 106.463611], color: "#fbbf24", radius: 500 }, 
    { name: "AREA COVERAGE RAJEG", coords: [-6.105, 106.510], color: "#3b82f6", radius: 3000 },
    { name: "CIRUMPAK", coords: [-6.0965, 106.4680], color: "#f43f5e", radius: 1500 },
    { name: "LEGOK SUKAMAJU", coords: [-6.1120, 106.4550], color: "#8b5cf6", radius: 1500 },
    { name: "KEMIRI", coords: [-6.075, 106.450], color: "#10b981", radius: 2000 },
    { name: "KEMUNING", coords: [-6.1349, 106.4435], color: "#10b981", radius: 1500 }
];

areas.forEach(area => {
    L.circle(area.coords, {
        color: area.color,
        fillColor: area.color,
        fillOpacity: 0.15,
        radius: area.radius 
    }).addTo(map).bindTooltip(area.name, {permanent: false, direction: 'center'});
});

// 5. FUNGSI CEK MANUAL
function cekSekarang() {
    const input = document.getElementById('inputWilayah').value.toUpperCase();
    const box = document.getElementById('boxHasil');
    
    box.classList.remove('hidden', 'bg-green-100', 'bg-yellow-100', 'bg-red-100', 'text-green-700', 'text-yellow-700', 'text-red-700');

    if (input === "") {
        alert("Woi, isi dulu nama desanya!");
        return;
    }

    // Database Sederhana Desa
    const aktif = ["JAMBU KARYA", "RAJEG", "CIRUMPAK", "LEGOK SUKAMAJU", "KEMIRI", "KEMUNING"];
    const proses = ["SINDANG JAYA", "SUKAMANAH", "TANJAKAN"];

    if (aktif.includes(input)) {
        box.innerHTML = `✅ MANTAP! Wilayah ${input} Sudah Tercover Sinyal Sanwanay!`;
        box.classList.add('bg-green-100', 'text-green-700');
    } else if (proses.includes(input)) {
        box.innerHTML = `⏳ Sabar Bro, Wilayah ${input} Sedang Dalam Proses Penarikan Kabel.`;
        box.classList.add('bg-yellow-100', 'text-yellow-700');
    } else {
        box.innerHTML = `❌ Waduh, Wilayah ${input} Belum Tercover. Hubungi Admin Buat Request!`;
        box.classList.add('bg-red-100', 'text-red-700');
    }
    box.classList.remove('hidden');
}

// 6. LEGENDA WARNA
const legend = L.control({ position: 'bottomleft' });
legend.onAdd = function(map) {
    const div = L.DomUtil.create('div', 'bg-white/90 p-4 rounded-3xl shadow-2xl border border-slate-200 text-[10px] font-bold text-blue-900');
    div.innerHTML = `
        <h4 class="mb-2 uppercase tracking-tighter border-b pb-1">Keterangan Sinyal</h4>
        <div class="flex items-center gap-2 mb-1"><span class="w-3 h-3 rounded-full" style="background:#fbbf24"></span> Pusat (Jambu Karya)</div>
        <div class="flex items-center gap-2 mb-1"><span class="w-3 h-3 rounded-full" style="background:#3b82f6"></span> Area Fiber Aktif</div>
        <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#f43f5e"></span> Area Perluasan</div>
    `;
    return div;
};
legend.addTo(map);
</script>

<style>
@keyframes bounce-short {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}
.animate-bounce-short {
  animation: bounce-short 0.6s ease-in-out infinite;
}
.leaflet-container { z-index: 1 !important; border-radius: 2rem; }
</style>

<%- include('partials/footer') %>