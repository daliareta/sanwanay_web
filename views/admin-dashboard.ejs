<%- include('partials/header') %>

<main class="container mx-auto mt-10 px-4 mb-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100 h-fit sticky top-24">
            <h3 class="text-xl font-bold text-blue-900 mb-6 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Posting Kegiatan
            </h3>
            <form action="/upload-kegiatan" method="POST" enctype="multipart/form-data" class="space-y-4">
                <div>
                    <label class="text-xs font-bold text-slate-500 ml-1">JUDUL</label>
                    <input type="text" name="judul" placeholder="Contoh: Pasang Baru" required 
                           class="w-full px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                
                <div>
                    <label class="text-xs font-bold text-slate-500 ml-1">LOKASI</label>
                    <input type="text" name="lokasi" placeholder="Contoh: Rajeg, Tangerang" required 
                           class="w-full px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-500 ml-1">DESKRIPSI</label>
                    <textarea name="deskripsi" placeholder="Ceritakan singkat kegiatannya..." required rows="3"
                              class="w-full px-4 py-2 rounded-xl bg-slate-50 border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-500 ml-1">FOTO KEGIATAN</label>
                    <input type="file" name="foto" required class="w-full text-sm mt-1 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-bold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                </div>

                <button class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg shadow-blue-200 mt-2">
                    Publish Kegiatan
                </button>
            </form>
        </div>

        <div class="lg:col-span-2 space-y-8">
            
            <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100">
                <h3 class="text-xl font-bold text-blue-900 mb-6">Pendaftar Masuk</h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-500 text-sm">
                                <th class="p-3 border-b">Nama</th>
                                <th class="p-3 border-b">WhatsApp</th>
                                <th class="p-3 border-b">Paket</th>
                                <th class="p-3 border-b text-center">KTP</th>
                                <th class="p-3 border-b text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="text-slate-700">
                            <% pendaftar.forEach(p => { %>
                            <tr class="hover:bg-slate-50 transition">
                                <td class="p-3 border-b font-medium"><%= p.nama %></td>
                                <td class="p-3 border-b text-blue-600 font-bold"><%= p.phone %></td>
                                <td class="p-3 border-b text-xs"><span class="bg-blue-100 text-blue-700 px-2 py-1 rounded-md"><%= p.paket %></span></td>
                                <td class="p-3 border-b text-center">
                                    <% if (p.ktp) { %>
                                        <button onclick="openKtpModal('<%= p.ktp %>', '<%= p.nama %>')" class="bg-blue-500 text-white px-2 py-1 rounded-lg text-[10px] font-bold hover:bg-blue-600 transition">
                                            LIHAT KTP
                                        </button>
                                    <% } else { %>
                                        <span class="text-slate-400 text-[10px]">No File</span>
                                    <% } %>
                                </td>
                                <td class="p-3 border-b text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <a href="https://wa.me/<%= p.phone %>" target="_blank" class="bg-green-500 text-white px-3 py-1.5 rounded-lg text-[10px] font-bold hover:bg-green-600 transition flex items-center gap-1">
                                            <span>CHAT</span>
                                        </a>
                                        <a href="/hapus-pendaftar/<%= p.id %>" 
                                           onclick="return confirm('Hapus data pendaftar <%= p.nama %>, Bro?')"
                                           class="text-red-500 hover:bg-red-50 p-1.5 rounded-lg transition border border-transparent hover:border-red-100">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                            <% if (pendaftar.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center py-6 text-slate-400 italic text-sm">Belum ada pendaftar baru.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="bg-white p-6 rounded-3xl shadow-xl border border-slate-100">
                <h3 class="text-xl font-bold text-blue-900 mb-6 italic text-yellow-500">Kelola Galeri (Hapus Data)</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% activities.forEach(item => { %>
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-2xl border border-slate-200 group">
                        <div class="flex items-center gap-3">
                            <img src="<%= item.foto %>" class="w-12 h-12 object-cover rounded-lg shadow-sm">
                            <div>
                                <p class="text-sm font-bold text-slate-800 line-clamp-1 uppercase"><%= item.judul %></p>
                                <p class="text-[10px] text-slate-500"><%= item.lokasi %></p>
                            </div>
                        </div>
                        <a href="/hapus-kegiatan/<%= item.id %>" 
                           onclick="return confirm('Beneran mau hapus foto ini, Bro?')"
                           class="text-red-500 hover:bg-red-50 p-2 rounded-xl transition">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </a>
                    </div>
                    <% }) %>
                    <% if (activities.length === 0) { %>
                        <p class="col-span-full text-center text-slate-400 py-4 italic text-sm">Belum ada foto kegiatan.</p>
                    <% } %>
                </div>
            </div>

        </div>
    </div>
</main>

<div id="ktpModal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-75 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl max-w-2xl w-full p-6 relative">
        <button onclick="closeKtpModal()" class="absolute -top-4 -right-4 bg-red-500 text-white w-10 h-10 rounded-full font-bold shadow-lg">X</button>
        <h4 id="ktpTitle" class="text-lg font-bold text-blue-900 mb-4 uppercase text-center"></h4>
        <div class="rounded-2xl overflow-hidden border-4 border-slate-100">
            <img id="ktpImg" src="" class="w-full h-auto object-contain max-h-[70vh]">
        </div>
        <div class="mt-4 flex justify-center">
            <a id="ktpDownload" href="" download class="bg-blue-600 text-white px-6 py-2 rounded-xl font-bold hover:bg-blue-700 transition">Download Gambar</a>
        </div>
    </div>
</div>

<script>
    function openKtpModal(imgUrl, userName) {
        document.getElementById('ktpImg').src = imgUrl;
        document.getElementById('ktpDownload').href = imgUrl;
        document.getElementById('ktpTitle').innerText = "KTP: " + userName;
        document.getElementById('ktpModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Stop scroll background
    }

    function closeKtpModal() {
        document.getElementById('ktpModal').classList.add('hidden');
        document.body.style.overflow = 'auto'; // Re-enable scroll
    }

    // Klik luar modal untuk tutup
    window.onclick = function(event) {
        const modal = document.getElementById('ktpModal');
        if (event.target == modal) {
            closeKtpModal();
        }
    }
</script>

<%- include('partials/footer') %>