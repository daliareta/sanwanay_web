    "addressLocality": "Rajeg",
    "addressRegion": "Kabupaten Tangerang",
    "postalCode": "15540",
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -6.128528, 
    "longitude": 106.463611
  },
  "openingHoursSpecification": {
